#include "resource.h"
#include <windows.h>
#include <commctrl.h>

// --------------------------------------------------------------------
//  Icon (extracted from original PriusLauncher.exe)
// --------------------------------------------------------------------
IDI_LAUNCHER ICON "assets\\launcher.ico"

// --------------------------------------------------------------------
//  Bitmap resources (embedded into the executable)
//  Default theme: 20100513_TW
// --------------------------------------------------------------------
IDB_MAIN_BG              BITMAP  "assets\\themes\\20100513_TW\\main_bg.bmp"

// Close button (no disabled state)
IDB_BTN_CLOSE_NORMAL     BITMAP  "assets\\themes\\20100513_TW\\btn_close_normal.bmp"
IDB_BTN_CLOSE_HOVER      BITMAP  "assets\\themes\\20100513_TW\\btn_close_hover.bmp"
IDB_BTN_CLOSE_PRESSED    BITMAP  "assets\\themes\\20100513_TW\\btn_close_pressed.bmp"

// Options button
IDB_BTN_OPTIONS_NORMAL   BITMAP  "assets\\themes\\20100513_TW\\btn_options_normal.bmp"
IDB_BTN_OPTIONS_HOVER    BITMAP  "assets\\themes\\20100513_TW\\btn_options_hover.bmp"
IDB_BTN_OPTIONS_PRESSED  BITMAP  "assets\\themes\\20100513_TW\\btn_options_pressed.bmp"
IDB_BTN_OPTIONS_DISABLED BITMAP  "assets\\themes\\20100513_TW\\btn_options_disabled.bmp"

// Start button
IDB_BTN_START_NORMAL     BITMAP  "assets\\themes\\20100513_TW\\btn_start_normal.bmp"
IDB_BTN_START_HOVER      BITMAP  "assets\\themes\\20100513_TW\\btn_start_hover.bmp"
IDB_BTN_START_PRESSED    BITMAP  "assets\\themes\\20100513_TW\\btn_start_pressed.bmp"
IDB_BTN_START_DISABLED   BITMAP  "assets\\themes\\20100513_TW\\btn_start_disabled.bmp"

// Progress bar (default theme)
IDB_SEP_FILL_TOTAL       BITMAP  "assets\\themes\\20100513_TW\\sep_fill_total.bmp"
IDB_SEP_TRACK_DISABLED   BITMAP  "assets\\themes\\20100513_TW\\sep_track_disabled.bmp"
IDB_SEP_TRACK_HOVER      BITMAP  "assets\\themes\\20100513_TW\\sep_track_hover.bmp"
IDB_SEP_FILL_CURRENT     BITMAP  "assets\\themes\\20100513_TW\\sep_fill_current.bmp"

