// --------------------------------------------------------------------
//  Main launcher dialog  (IDD_MAIN = 101)
//  Actual pixel size (825x510) is forced in WM_INITDIALOG.
//  Controls are repositioned to exact pixel coords in code.
// --------------------------------------------------------------------
IDD_MAIN DIALOGEX 0, 0, 305, 214
STYLE DS_SETFONT | WS_POPUP | WS_CLIPCHILDREN
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL  "", IDC_BTN_OPTIONS, "BUTTON", BS_OWNERDRAW | WS_CHILD | WS_VISIBLE | WS_TABSTOP,  80, 187, 70, 19
    CONTROL  "", IDC_BTN_START,   "BUTTON", BS_OWNERDRAW | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 155, 187, 70, 19
    CONTROL  "", IDC_BTN_EXIT,    "BUTTON", BS_OWNERDRAW | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 230, 187, 70, 19
END

// --------------------------------------------------------------------
//  Options dialog  (IDD_OPTIONS = 102)
// --------------------------------------------------------------------
IDD_OPTIONS DIALOGEX 0, 0, 300, 300
STYLE 0x80CF0848
CAPTION "Game Options"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    CONTROL       "", IDC_TREE_OPTIONS, "SysTreeView32",
                  TVS_HASBUTTONS | TVS_LINESATROOT | TVS_SHOWSELALWAYS | TVS_FULLROWSELECT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP | WS_CLIPSIBLINGS,
                  4, 4, 292, 218
    CONTROL       "", -1, "STATIC", SS_SUNKEN | WS_CHILD | WS_VISIBLE, 4, 226, 292, 34
    LTEXT         "", IDC_LBL_PROPNAME, 8, 230, 284, 10
    PUSHBUTTON    "Default Settings", IDC_BTN_DEFAULTS, 4, 264, 292, 14
    DEFPUSHBUTTON "Confirm (&O)",     IDOK,             4, 282, 144, 14
    PUSHBUTTON    "Cancel (&C)",      IDCANCEL,         152, 282, 144, 14
END

